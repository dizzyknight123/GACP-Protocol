      "responsibilities": ["Plan routes", "Optimize routes"]
    },
    {
      "agent_id": "fleet_agent",
      "capabilities": ["manage_fleet", "assign_vehicles"],
      "responsibilities": ["Manage fleet", "Assign vehicles"]
    },
    {
      "agent_id": "tracking_agent",
      "capabilities": ["track_shipment", "update_status"],
      "responsibilities": ["Track shipments", "Update status"]
    }
  ],
  "terms": {
