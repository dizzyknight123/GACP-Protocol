# GACP 协议环境配置文件
# 优先使用免费大模型，API Key 可选填写

# OpenAI API Key（可选）
# OPENAI_API_KEY=your_openai_api_key

# 通义千问 API Key（可选）
# DASHSCOPE_API_KEY=your_dashscope_api_key

# 其他配置
GACP_MODE=mock  # mock 模式使用模拟数据，无需 API Key
GACP_LOG_LEVEL=info  # 日志级别: debug, info, warning, error
GACP_VALIDATION_NODES=10  # 验证节点数量

# 智能体配置
BOOKING_AGENT_ENABLED=true
TRANSPORTATION_AGENT_ENABLED=true
REIMBURSEMENT_AGENT_ENABLED=true

# 模拟模式配置（当 GACP_MODE=mock 时生效）
MOCK_FLIGHT_PRICE=1200
MOCK_HOTEL_PRICE=1500
MOCK_TRANSPORT_PRICE=200